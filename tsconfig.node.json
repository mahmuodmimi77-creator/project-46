export type UserRole = 'user' | 'admin';

export interface User {
  id: string;
  name: string;
  email: string;
  phone: string;
  role: UserRole;
  avatarUrl?: string;
}

export type TripType = 'boat' | 'farm';

export interface Trip {
  id: string;
  title: string;
  description: string;
  type: TripType;
  location: string;
  city: string;
  pricePerPerson: number;
  maxCapacity: number;
  durationHours: number;
  images: string[]; // URLs or gradient placeholders
  amenities: string[];
  availableDates: string[]; // YYYY-MM-DD
  isActive: boolean;
  rating: number;
  reviewCount: number;
}

export type BookingStatus = 'pending' | 'confirmed' | 'cancelled';

export interface Booking {
  id: string;
  userId: string;
  tripId: string;
  bookingDate: string;
  numberOfPeople: number;
  totalPrice: number;
  status: BookingStatus;
  notes?: string;
  createdAt: string;
}

export interface Review {
  id: string;
  userId: string;
  tripId: string;
  rating: number;
  comment: string;
  createdAt: string;
  user?: User; // Expanded for UI
}