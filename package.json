import React, { useState } from 'react';
import { motion } from 'framer-motion';
import { User, Mail, Phone, Edit2, LogOut, Shield, Map } from 'lucide-react';
import { useAuth } from '../context/AuthContext';
export function Profile() {
  const { user, logout } = useAuth();
  const [isEditing, setIsEditing] = useState(false);
  const [name, setName] = useState(user?.name || '');
  const [phone, setPhone] = useState(user?.phone || '');
  const handleSave = () => {
    // In a real app, update user profile via API
    setIsEditing(false);
  };
  if (!user) return null;
  return (
    <div className="bg-background min-h-screen pt-4 md:pt-8 pb-24">
      <div className="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 className="text-3xl font-display font-bold text-text-primary mb-6">
          حسابي
        </h1>

        <div className="space-y-6">
          {/* Profile Header Card */}
          <motion.div
            initial={{
              opacity: 0,
              y: 20
            }}
            animate={{
              opacity: 1,
              y: 0
            }}
            className="bg-white rounded-3xl shadow-soft p-6 md:p-8 border border-gray-100 text-center relative overflow-hidden">
            
            <div className="absolute top-0 left-0 right-0 h-32 bg-gradient-to-r from-primary to-primary-light" />

            <div className="relative z-10">
              <div className="w-24 h-24 bg-white rounded-full p-1 mx-auto mb-4 shadow-md">
                <div className="w-full h-full bg-gray-100 rounded-full flex items-center justify-center text-primary text-3xl font-bold">
                  {user.name.charAt(0)}
                </div>
              </div>

              <h2 className="text-2xl font-bold text-text-primary mb-1">
                {user.name}
              </h2>
              <p className="text-text-muted mb-6">{user.email}</p>

              <div className="flex justify-center space-x-4 space-x-reverse">
                <div className="bg-gray-50 px-6 py-3 rounded-2xl border border-gray-100">
                  <div className="text-2xl font-bold text-primary mb-1">2</div>
                  <div className="text-xs text-text-muted">حجوزات</div>
                </div>
                <div className="bg-gray-50 px-6 py-3 rounded-2xl border border-gray-100">
                  <div className="text-2xl font-bold text-accent mb-1">0</div>
                  <div className="text-xs text-text-muted">تقييمات</div>
                </div>
              </div>
            </div>
          </motion.div>

          {/* Personal Info Card */}
          <motion.div
            initial={{
              opacity: 0,
              y: 20
            }}
            animate={{
              opacity: 1,
              y: 0
            }}
            transition={{
              delay: 0.1
            }}
            className="bg-white rounded-3xl shadow-soft p-6 md:p-8 border border-gray-100">
            
            <div className="flex justify-between items-center mb-6">
              <h3 className="text-xl font-bold flex items-center">
                <User className="w-5 h-5 ml-2 text-primary" />
                المعلومات الشخصية
              </h3>
              {!isEditing ?
              <button
                onClick={() => setIsEditing(true)}
                className="text-primary hover:bg-primary/5 p-2 rounded-lg transition-colors flex items-center text-sm font-medium">
                
                  <Edit2 className="w-4 h-4 ml-1" />
                  تعديل
                </button> :

              <div className="flex space-x-2 space-x-reverse">
                  <button
                  onClick={() => setIsEditing(false)}
                  className="text-text-muted hover:bg-gray-100 p-2 rounded-lg transition-colors text-sm font-medium">
                  
                    إلغاء
                  </button>
                  <button
                  onClick={handleSave}
                  className="text-white bg-primary hover:bg-primary-dark px-4 py-2 rounded-lg transition-colors text-sm font-medium shadow-sm">
                  
                    حفظ
                  </button>
                </div>
              }
            </div>

            <div className="space-y-4">
              <div>
                <label className="block text-sm font-medium text-text-muted mb-1">
                  الاسم بالكامل
                </label>
                {isEditing ?
                <input
                  type="text"
                  value={name}
                  onChange={(e) => setName(e.target.value)}
                  className="w-full p-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:border-primary" /> :


                <div className="p-3 bg-gray-50 rounded-xl border border-transparent font-medium">
                    {user.name}
                  </div>
                }
              </div>

              <div>
                <label className="block text-sm font-medium text-text-muted mb-1">
                  البريد الإلكتروني
                </label>
                <div className="flex items-center p-3 bg-gray-50 rounded-xl border border-transparent">
                  <Mail className="w-4 h-4 text-gray-400 ml-2" />
                  <span className="font-medium text-gray-500" dir="ltr">
                    {user.email}
                  </span>
                  <span className="mr-auto text-xs bg-gray-200 text-gray-600 px-2 py-1 rounded">
                    لا يمكن تعديله
                  </span>
                </div>
              </div>

              <div>
                <label className="block text-sm font-medium text-text-muted mb-1">
                  رقم الهاتف
                </label>
                {isEditing ?
                <input
                  type="tel"
                  dir="ltr"
                  value={phone}
                  onChange={(e) => setPhone(e.target.value)}
                  className="w-full p-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:border-primary text-left" /> :


                <div className="flex items-center p-3 bg-gray-50 rounded-xl border border-transparent">
                    <Phone className="w-4 h-4 text-gray-400 ml-2" />
                    <span className="font-medium" dir="ltr">
                      {user.phone}
                    </span>
                  </div>
                }
              </div>
            </div>
          </motion.div>

          {/* Settings & Actions */}
          <motion.div
            initial={{
              opacity: 0,
              y: 20
            }}
            animate={{
              opacity: 1,
              y: 0
            }}
            transition={{
              delay: 0.2
            }}
            className="bg-white rounded-3xl shadow-soft border border-gray-100 overflow-hidden">
            
            <div className="divide-y divide-gray-100">
              <button className="w-full flex items-center justify-between p-4 hover:bg-gray-50 transition-colors">
                <div className="flex items-center">
                  <Shield className="w-5 h-5 text-gray-400 ml-3" />
                  <span className="font-medium">الأمان وكلمة المرور</span>
                </div>
                <ChevronLeftIcon className="w-5 h-5 text-gray-300" />
              </button>
              <button className="w-full flex items-center justify-between p-4 hover:bg-gray-50 transition-colors">
                <div className="flex items-center">
                  <Map className="w-5 h-5 text-gray-400 ml-3" />
                  <span className="font-medium">اللغة والمنطقة</span>
                </div>
                <div className="flex items-center">
                  <span className="text-sm text-text-muted mr-2">
                    العربية (مصر)
                  </span>
                  <ChevronLeftIcon className="w-5 h-5 text-gray-300" />
                </div>
              </button>
              <button
                onClick={logout}
                className="w-full flex items-center p-4 hover:bg-red-50 text-error transition-colors">
                
                <LogOut className="w-5 h-5 ml-3" />
                <span className="font-medium">تسجيل الخروج</span>
              </button>
            </div>
          </motion.div>
        </div>
      </div>
    </div>);

}
// Helper icon
function ChevronLeftIcon(props: any) {
  return (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      strokeWidth="2"
      strokeLinecap="round"
      strokeLinejoin="round"
      {...props}>
      
      <path d="m15 18-6-6 6-6" />
    </svg>);

}